datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  currency      String    @default("USD")
  timezone      String    @default("UTC")
  riskUnit      String    @default("dollar")
  accountSize   Float?
  seeded        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  trades     Trade[]
  goals      Goal[]
  playbooks  Playbook[]
  reviews    Review[]
  backtests  Backtest[]
}

model Trade {
  id              String    @id @default(cuid())
  userId          String
  symbol          String
  assetClass      String
  direction       String
  status          String
  outcome         String?
  entryDate       DateTime
  exitDate        DateTime?
  entryPrice      Float
  exitPrice       Float?
  quantity        Float
  commission      Float     @default(0)
  grossPnl        Float?
  netPnl          Float?
  rMultiple       Float?
  returnPct       Float?
  stopLoss        Float?
  takeProfit      Float?
  initialRisk     Float?
  playbookId      String?
  strategy        String?
  session         String?
  tags            String[]
  notes           String    @default("")
  screenshotUrls  String[]
  setupRating     Int?
  executionRating Int?
  emotionRating   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbook Playbook? @relation(fields: [playbookId], references: [id])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  type         String
  period       String
  targetValue  Float
  currentValue Float    @default(0)
  unit         String
  startDate    String
  endDate      String
  isActive     Boolean  @default(true)
  isCompleted  Boolean  @default(false)
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Playbook {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  description          String?
  marketCondition      String?
  entryCriteria        String?
  invalidationCriteria String?
  managementRules      String?
  exitCriteria         String?
  screenshotUrl        String?
  checklist            Json     @default("[]")
  tags                 String[]
  isActive             Boolean  @default(true)
  tradeCount           Int?
  winRate              Float?
  avgRMultiple         Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
}

model Review {
  id              String   @id @default(cuid())
  userId          String
  type            String
  date            String
  emotionalState  String?
  disciplineScore Int?
  notes           String?
  wins            String?
  losses          String?
  improvements    String?
  habits          Json     @default("[]")
  tradeCount      Int?
  dayPnl          Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
}

model Backtest {
  id             String   @id @default(cuid())
  userId         String
  name           String
  strategy       String
  description    String?
  startDate      String
  endDate        String
  initialCapital Float
  trades         Json     @default("[]")
  totalPnl       Float?
  winRate        Float?
  profitFactor   Float?
  maxDrawdown    Float?
  sharpeRatio    Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
